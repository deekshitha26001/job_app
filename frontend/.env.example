VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_here

# Google OAuth — get from https://console.cloud.google.com (Credentials → OAuth 2.0 Client IDs)
# Authorized redirect URI to add: http://localhost:3000/auth/callback/google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# GitHub OAuth — get from https://github.com/settings/developers (New OAuth App)
# Authorization callback URL to set: http://localhost:3000/auth/callback/github
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# Backend secrets (set in backend application.properties, NOT here)
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GITHUB_CLIENT_SECRET=your_github_client_secret
